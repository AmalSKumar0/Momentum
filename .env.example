# Database Connection Settings
# For local Docker development, DB_HOST should be set to "db".
# For external hosting (like Vercel), set these to your remote database credentials.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=habit_tracker
DB_PORT=3306
# DB_SSL_CA=ca.pem # Set path relative to project root or absolute if using SSL (e.g. Aiven)

# Contact Form & Email Settings
CONTACT_TO_EMAIL=amalskumardev@gmail.com
CONTACT_FROM_EMAIL=noreply@amalskumar.dev

# SMTP Settings (Optional, falls back to native mail() if host is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls

